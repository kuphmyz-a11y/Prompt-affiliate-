# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Auth
JWT_SECRET=change_me_in_production

# Database
DATABASE_URL=./db/app.sqlite

# Hybrid mode
MOCK_MODE=false

# OpenAI (required for AI features)
OPENAI_API_KEY=sk-...

# External integrations (all optional – fallback to mock if missing)
WORDPRESS_URL=https://yoursite.com
WORDPRESS_USER=admin
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
MAKE_WEBHOOK_URL=https://hook.eu2.make.com/xxxxx
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
